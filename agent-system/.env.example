# Copy this file to .env and fill in real values. Never commit .env itself.

# Choose one provider: "google" (free tier), "anthropic", or "openai"
LLM_PROVIDER=google

# --- Google Gemini (FREE TIER) ---
# Get a free API key at https://aistudio.google.com/app/apikey
# No credit card required. Real no-cost daily quota on Gemini Flash models.
GOOGLE_API_KEY=your_google_ai_studio_key_here
GOOGLE_MODEL=gemini-2.5-flash

# --- Anthropic (paid, no ongoing free tier) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Check the current model list at https://docs.claude.com before setting this
ANTHROPIC_MODEL=claude-sonnet-5

# --- OpenAI (paid, no ongoing free tier) ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Name of the Docker container running target-app (must match what you
# pass to `docker run --name` or the service name in docker-compose.yml)
TARGET_CONTAINER=sre-target-app

# Base URL the agent uses to verify recovery via /health
TARGET_APP_URL=http://localhost:3000

# Where ChromaDB persists its local vector store
CHROMA_PERSIST_DIR=./chroma_store
